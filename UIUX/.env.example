# Frontend env for Vercel or local preview.
# Leave empty in local dev if you want to use the Vite proxy to http://127.0.0.1:3001.
VITE_API_BASE_URL=""

# Backend env for Railway or local API server.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
CRM_AGENT_MODEL="gemini-2.5-flash"
GETFLY_API_KEY="MY_GETFLY_API_KEY"
GETFLY_BASE_URL="https://jega.getflycrm.com/"
PREBUILD_DASHBOARD_DB="true"
SYNC_ADMIN_TOKEN="CHANGE_ME_TO_A_RANDOM_SECRET"
SYNC_DEFAULT_MODE="auto"
SYNC_LOOKBACK_HOURS="6"
SYNC_ON_BOOT="auto"
SYNC_INTERVAL_MINUTES="360"
SYNC_CUSTOMER_AUTO_LIMIT_PAGES="50"
SYNC_CUSTOMER_AUTO_PAGE_SIZE="100"
SYNC_CUSTOMER_AUTO_WORKERS="4"

# Optional: point the backend at a mounted Railway volume.
# CRM_DATA_DIR="/app/data"
# CRM_DB_PATH="/app/data/crm.db"
# DASHBOARD_DB_PATH="/app/data/dashboard_sales.db"

# Optional env for the cron trigger service.
# SYNC_TRIGGER_URL="https://crm-dashboard-app-production.up.railway.app/api/admin/sync"
# SYNC_TRIGGER_MODE="incremental"
