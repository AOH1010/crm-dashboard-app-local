# Frontend env for Vercel or local preview.
# Leave empty in local dev if you want to use the Vite proxy to http://127.0.0.1:3001.
VITE_API_BASE_URL=""

# Backend env for Railway or local API server.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
CRM_AGENT_MODEL="gemini-2.5-flash"
PREBUILD_DASHBOARD_DB="true"

# Optional: point the backend at a mounted Railway volume instead of the baked-in /app/data snapshot.
# CRM_DATA_DIR="/data"
# CRM_DB_PATH="/data/crm.db"
# DASHBOARD_DB_PATH="/data/dashboard_sales.db"
