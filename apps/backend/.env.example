# Backend env for the local API server.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"
CRM_AGENT_PROVIDER="gemini"
CRM_AGENT_MODEL="gemini-2.5-flash"
GETFLY_API_KEY="MY_GETFLY_API_KEY"
GETFLY_BASE_URL="https://jega.getflycrm.com/"
PREBUILD_DASHBOARD_DB="true"
SYNC_ADMIN_TOKEN="CHANGE_ME_TO_A_RANDOM_SECRET"
SYNC_DEFAULT_MODE="auto"
SYNC_LOOKBACK_HOURS="6"
SYNC_ON_BOOT="false"
SYNC_INTERVAL_MINUTES="0"
SYNC_CUSTOMER_AUTO_LIMIT_PAGES="50"
SYNC_CUSTOMER_AUTO_PAGE_SIZE="100"
SYNC_CUSTOMER_AUTO_WORKERS="4"
CRM_AGENT_MAX_TOKENS="16384"
CRM_AGENT_TEMPERATURE="0.15"
CRM_AGENT_TOP_P="0.95"
CRM_DATA_CONNECTOR=sqlite
CRM_AGENT_DB_SCHEMA=crm_agent
# Supabase pooler example. Replace PROJECT_REF / REGION / password with the new project values.
# For a Singapore project, REGION is typically `ap-southeast-1`.
SUPABASE_DATABASE_URL="postgresql://crm_agent_readonly.PROJECT_REF:REPLACE_ME@aws-REGION.pooler.supabase.com:6543/postgres"
SUPABASE_POOL_MAX="1"
SUPABASE_POOL_IDLE_TIMEOUT_MS="30000"
SUPABASE_POOL_CONNECTION_TIMEOUT_MS="10000"
# Admin/seed connection for one-off load or V2.5 ingestion bootstrap.
# Use a URL-safe password here. If your password contains @, :, /, or %, URL-encode it or choose a simpler temporary password.
# SUPABASE_SEED_DATABASE_URL="postgresql://postgres.PROJECT_REF:REPLACE_ME@aws-REGION.pooler.supabase.com:6543/postgres"
# Optional: point the backend at a custom mounted data directory.
# CRM_DATA_DIR="/app/data"
# CRM_DB_PATH="/app/data/crm.db"
# DASHBOARD_DB_PATH="/app/data/dashboard_sales.db"

# V2 optional: switch AI chat data plane from local SQLite to Supabase after parity is ready.
# Keep sqlite as default until Supabase schema/data have been seeded and parity-tested.
# CRM_DATA_CONNECTOR="sqlite"
# CRM_DATA_CONNECTOR="supabase"
# CRM_AGENT_DB_SCHEMA="crm_agent"
# Singapore pooler example:
# SUPABASE_DATABASE_URL="postgresql://crm_agent_readonly.NEW_PROJECT_REF:REPLACE_ME@aws-ap-southeast-1.pooler.supabase.com:6543/postgres"
# SUPABASE_SEED_DATABASE_URL="postgresql://postgres.NEW_PROJECT_REF:REPLACE_ME@aws-ap-southeast-1.pooler.supabase.com:6543/postgres"
# SUPABASE_DATABASE_URL="postgresql://crm_agent_readonly.PROJECT_REF:REPLACE_ME@aws-REGION.pooler.supabase.com:6543/postgres"
# SUPABASE_DIRECT_URL="postgresql://crm_agent_readonly:REPLACE_ME@db.PROJECT_REF.supabase.co:5432/postgres"

# Optional env for an external cron trigger service.
# SYNC_TRIGGER_URL="http://127.0.0.1:3001/api/admin/sync"
# SYNC_TRIGGER_MODE="auto"
