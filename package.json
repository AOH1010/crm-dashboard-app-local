{
  "name": "crm-dashboard-root",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "modules/ai-chat"
  ],
  "scripts": {
    "dev": "node scripts/start-local-stack.mjs",
    "stop": "node scripts/stop-local-stack.mjs",
    "clean": "node scripts/clean-local-artifacts.mjs",
    "test:ai-chat": "npm run test --workspace @crm/ai-chat-module",
    "eval:ai-chat": "npm run eval --workspace @crm/ai-chat-module",
    "dev:web": "npm run dev --workspace @crm/frontend",
    "dev:api": "npm run dev --workspace @crm/backend",
    "start:api": "npm run start --workspace @crm/backend",
    "build": "npm run build --workspace @crm/frontend",
    "build:dashboard-db": "npm run build:dashboard-db --workspace @crm/backend",
    "lint": "npm run lint --workspace @crm/frontend",
    "check": "powershell -ExecutionPolicy Bypass -File .\\tools\\local-development\\verify-local-environment.ps1",
    "v2:sql-audit": "node scripts/v2-sql-dialect-audit.mjs",
    "v2:export-supabase-seed": "node --experimental-sqlite scripts/export-supabase-seed.mjs",
    "v2:generate-supabase-seed-sql": "node scripts/generate-supabase-seed-sql.mjs",
    "v2:seed-supabase": "node scripts/seed-supabase-from-export.mjs",
    "v2:supabase-smoke": "node scripts/supabase-smoke-check.mjs",
    "v2:supabase-parity-smoke": "node --experimental-sqlite scripts/supabase-parity-smoke.mjs"
  }
}
